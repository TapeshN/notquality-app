# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/notquality
# Neon:  postgresql://user:password@ep-xxx.neon.tech/notquality?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/notquality"

# Session secret — must be at least 32 characters
# Generate: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-32-char-minimum-secret"

# Environment
NODE_ENV="development"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXTAUTH_SECRET=""
AUTH_SECRET=""
# Must match the origin you open in the browser. Using https://production while on
# http://localhost breaks PKCE cookies (Secure cookies not sent over HTTP).
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel + custom domain): set to the canonical public URL. If unset,
# Auth.js may infer VERCEL_URL (deployment host) and GitHub OAuth redirect_uri will not match the app.
AUTH_URL=""
